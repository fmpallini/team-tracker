#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
gate_ok()   { echo -e "${GREEN}[ OK ]${NC}  $1"; }
gate_fail() { echo -e "${RED}[ FAIL ]${NC} $1 — $2"; exit 1; }
gate_warn() { echo -e "${YELLOW}[ WARN ]${NC} $1"; }
gate_run()  { echo -e "\n${BLUE}[ RUNNING ]${NC} $1..."; }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Pre-push quality gate"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 1. TypeCheck
gate_run "TypeCheck"
if npx tsc --noEmit 2>&1; then
  gate_ok "TypeCheck"
else
  gate_fail "TypeCheck" "fix type errors above then push again"
fi

# 2. Tests
gate_run "Tests"
if npx vitest run 2>&1; then
  gate_ok "Tests"
else
  gate_fail "Tests" "fix failing tests then push again"
fi

# 3. Security audit
gate_run "Security audit"
AUDIT_OUT=$(npm audit --json 2>/dev/null || true)
HIGH_COUNT=$(printf '%s' "$AUDIT_OUT" | node -e "
  let r=''; process.stdin.on('data',d=>r+=d);
  process.stdin.on('end',()=>{
    try{const d=JSON.parse(r); const s=d.metadata&&d.metadata.vulnerabilities||{}; console.log((s.high||0)+(s.critical||0));}
    catch{console.log(0);}
  });
" 2>/dev/null || echo 0)
MOD_COUNT=$(printf '%s' "$AUDIT_OUT" | node -e "
  let r=''; process.stdin.on('data',d=>r+=d);
  process.stdin.on('end',()=>{
    try{const d=JSON.parse(r); const s=d.metadata&&d.metadata.vulnerabilities||{}; console.log(s.moderate||0);}
    catch{console.log(0);}
  });
" 2>/dev/null || echo 0)
if [ "$HIGH_COUNT" -gt 0 ] 2>/dev/null; then
  npm audit --audit-level=high 2>&1 || true
  gate_fail "Security audit" "high/critical vulnerabilities found — run: npm audit fix"
elif [ "$MOD_COUNT" -gt 0 ] 2>/dev/null; then
  gate_warn "Security audit — $MOD_COUNT moderate vulnerabilities (run: npm audit for details)"
  gate_ok "Security audit (moderate — advisory only)"
else
  gate_ok "Security audit"
fi

# 4. Outdated packages (advisory only, non-blocking)
gate_run "Outdated packages"
OUTDATED=$(npm outdated --json 2>/dev/null || true)
if [ -n "$OUTDATED" ] && [ "$OUTDATED" != "{}" ]; then
  gate_warn "Outdated packages (safe minor/patch updates available):"
  printf '%s' "$OUTDATED" | node -e "
    let raw = '';
    process.stdin.on('data', d => raw += d);
    process.stdin.on('end', () => {
      try {
        const data = JSON.parse(raw);
        for (const [pkg, info] of Object.entries(data)) {
          const cur = (info.current || '').split('.')[0];
          const want = (info.wanted || '').split('.')[0];
          if (cur && want && cur === want && info.current !== info.wanted) {
            process.stdout.write('  ' + pkg.padEnd(20) + info.current + ' -> ' + info.wanted + '\n');
          }
        }
      } catch {}
    });
  " 2>/dev/null || true
  echo "  Run: npm update"
else
  gate_ok "Outdated packages"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${GREEN} All gates passed. Pushing...${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
